<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or 'One Engine Docs' }}</title>
  <style>
    :root { color-scheme: dark; }
    body { margin: 0; font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #0b0d13; color: #e5e7eb; }
    header { background: #111827; padding: 14px 20px; border-bottom: 1px solid #1f2937; position: sticky; top: 0; z-index: 9; }
    header a { color: #93c5fd; text-decoration: none; font-weight: 600; }
    main { padding: 20px; max-width: 980px; margin: 0 auto; }
    h1, h2, h3 { color: #e5e7eb; }
    a { color: #93c5fd; }
    .grid { display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
    .card { background: #0f172a; border: 1px solid #1f2937; padding: 12px; border-radius: 8px; }
    .tag { display: inline-block; padding: 2px 8px; border-radius: 999px; background: #1f2937; color: #9ca3af; font-size: 12px; margin-right: 6px; }
    footer { color: #9ca3af; padding: 24px; text-align: center; border-top: 1px solid #1f2937; }
    .muted { color: #9ca3af; }
  </style>
</head>
<body>
  <header>
    <a href="/docs/index.html">One Engine Docs</a>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <span class="muted">Generated with Eleventy · GitHub Pages ready</span>
  </footer>
</body>
</html>
