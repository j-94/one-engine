---
layout: layout.njk
pagination:
  data: catalog.patterns
  size: 1
  alias: item
permalink: "/docs/patterns/{{ item.id }}.html"
---

<h1>{{ item.title }}</h1>
<p class="muted">{{ item.summary }}</p>
<div>
  {% for t in item.tags %}<span class="tag">{{ t }}</span>{% endfor %}
</div>
<hr />
{% if item.docs_path %}
  {{ rawfile(item.docs_path) | safe }}
{% else %}
  <p>No doc page found.</p>
{% endif %}
